{
  "name": "wabi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx tsx watch app.ts",
    "build:f": "next build",
    "clean:b": "rimraf backend/dist",
    "compile:b": "tsc --project backend/tsconfig.json",
    "build:b": "run-s clean:b compile:b",
    "start": "npx tsx app.ts",
    "lint": "eslint",
    "db:generate": "npx prisma generate",
    "db:dev": "npx prisma migrate dev --name init",
    "db:reset": "npx prisma migrate reset --force",
    "db:push": "npx prisma db push  ",
    "db:seed": "npx tsx backend/prisma/seed.ts",
    "db:format": "npx prisma format",
    "better:generate": "npx @ generate --config backend/lib/auth.ts --output backend/prisma/schema/auth.prisma"
  },
  "dependencies": {
